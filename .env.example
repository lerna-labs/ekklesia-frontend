# Ekklesia Voting Frontend Environment Variables
# Copy this file to .env and fill in your values

# Base API URL for the backend API (the `/api` root; do NOT include `/v0` or `/v1`)
# The frontend appends `/v0/...` or `/v1/...` per call site.
# Example: http://localhost:3000/api or https://api.example.com/api
VITE_API_URL=

# Server status endpoint URL (external endpoint)
# Used to check server availability and network status
# Example: http://localhost:3000/api/status or https://api.example.com/status
VITE_SERVER_STATUS=

# Cardano Network ID
# Used for wallet connection and signing operations
# Example: 0 (testnet/preview) or 1 (mainnet)
VITE_NETWORK_ID=

# Allowed sign-with types offered in the WalletSigner dialog.
# Comma-separated subset of: drep, stake, pool, addr
# Example: drep,stake,pool,addr
VITE_WALLETSIGNER_USER_TYPES=

# Default sign-with type used when the user has not yet made a choice.
# Must be one of the values listed in VITE_WALLETSIGNER_USER_TYPES.
# Example: stake
VITE_WALLETSIGNER_USER_DEFAULT=

# Enable the MultiSig toggle in the WalletSigner dialog.
# Set to "true" to expose native-script multisig login + voting.
VITE_WALLETSIGNER_MULTISIG=

# ─── Branding / OpenGraph ────────────────────────────────────────────────
# Build-time customization for app title, social cards, manifest, header.
# Anything left blank falls back to the generic Ekklesia defaults.

# Visible app name in the header + manifest (short, e.g. "Ekklesia",
# "Ekklesia × Intersect", "Ekklesia × CIWG").
VITE_APP_NAME=

# Browser tab title + OG/Twitter title. Should include the brand name and
# a short "what this is" hook. Example:
# "Ekklesia — Verifiable, Hydra-Powered Voting on Cardano"
VITE_APP_TITLE=

# Meta description (~155 chars max) used for OG/Twitter/SEO.
VITE_APP_DESCRIPTION=

# Canonical URL of this deployment, used for og:url / twitter:url and
# the absolute og:image URL. Omit trailing slash. If unset, the URL meta
# tags are skipped entirely. Example: https://app.ekklesia.vote
VITE_APP_URL=

# Path (relative to the site root) of the social card image. Defaults to
# /social.png — swap the file in static/ to rebrand. Override only if you
# need a non-standard filename.
VITE_APP_OG_IMAGE=

# Twitter handle used for twitter:site / twitter:creator. Include the @.
# Example: @adamkdean
VITE_APP_TWITTER_HANDLE=

# ─── Editorial content + theme layer ────────────────────────────────────
# Selects which deployment-specific bundle under content/<name>/ is
# layered on top of content/_default/. The bundle holds two things:
#   1. Editorial markdown (content/<name>/<lang>/<slot>/<slug>.md) —
#      frontmatter for structured fields, body for rich text. Same-
#      relative-path files override the default; new files extend it
#      (e.g. add FAQs).
#   2. Optional theme overrides (content/<name>/theme.json) — a flat
#      JSON object overriding brand-visible CSS tokens (primary, accent,
#      ring, radius, font-heading, font-body, etc.). Partial overrides
#      fall through to the defaults in src/app.css. See
#      src/lib/base/theme.js for the full schema.
# Leave unset (or set to "_default") to ship the generic Ekklesia copy.
# Example values: intersect, ciwg, _default
VITE_APP_CONTENT=

# Note: VITE_APP_VERSION is automatically set from package.json during build
# and does not need to be configured in .env
